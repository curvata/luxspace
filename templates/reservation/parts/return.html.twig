<table class="table-info">
    <tbody>
        <tr>
            <td>Référence:</td>
            <td><span class="flight_ref">{{ return.reference }}</span></td>
        </tr>
        <tr>
            <td>Fusée:</td>
            <td><span class="list_rocket_name">{{ return.rocket }}</span></td>
        </tr>
        <tr>
            <td>Date:</td>
            <td><span class="list_date">{{ return.date|format_date('long', locale='fr') }}</span></td>
        </tr>
        <tr>
            <td>Heure:</td>
            <td><span class="list_time">{{ return.date|date('H:i') }}</span></td>
        </tr>
        <tr>
            <td>Durée:</td>
            <td><span class="list_hour">{{ return.duration }}h de vol</span></td>
        </tr>
        <tr>
            <td>Prix:</td>
            <td><span class="price">{{ return.price|number_format(2, '.', ',') }} €</span></td>
        </tr>
    </tbody>
</table>