{% extends 'base.html.twig' %}

{% block title %}LUXSPACE - Réservation des vols{% endblock %}
{% block description %}
    <meta name="description" content="Récapitulatif des vols et encodage des passagers" />
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="https://polyfill.io/v3/polyfill.min.js?version=3.52.1&features=fetch"></script>
{% endblock %}

{% block body %}
<div class="container">
    <main>
        <h1 class="htitle_center">Réservation pour 
            {% if departure.destination.title == 'Lune' %}la {% endif %}{{ departure.destination.title }}
        </h1>
        <p class="subtitle"><span>{{ departure.destination.shortDescription }}</span></p>
        <section class="flights">
                <article class="flight">
                    <div class="ico"><i class="fa-solid fa-rocket ico_fa dep"></i><h2>Vol aller</h2></div>
                    <div class="card">
                        <div class="card_image">
                            <img src="{{ asset('images/location/' ~ departure.destination.pictureHeader) }}" alt="{{ departure.destination.title }}" loading="lazy">
                        </div>
                        <div class="card_title">
                            <div class="card_route">
                                <span class="card_route__city">LUXEMBOURG</span>
                                <span class="card_route__sep">✦</span>
                                <span class="card_route__city">{{ departure.destination|upper }}</span>
                            </div>
                        </div>
                        <div class="card_content">
                            {% include "reservation/parts/departure.html.twig" %}
                        </div>
                    </div>
                </article>
                <article class="flight">
                    <div class="ico"><i class="fa-solid fa-rocket ico_fa ret"></i><h2>Vol retour</h2></div>
                    <div class="card">
                        <div class="card_image">
                            <img src="{{ asset('images/location/' ~ return.ffrom.pictureHeader) }}" alt="{{ return.ffrom.title }}" loading="lazy">
                        </div>
                        <div class="card_title">
                            <div class="card_route">
                                <span class="card_route__city">{{ return.ffrom|upper }}</span>
                                <span class="card_route__sep">✦</span>
                                <span class="card_route__city">LUXEMBOURG</span>
                            </div>
                        </div>
                        <div class="card_content">
                            {% include "reservation/parts/return.html.twig" %}
                        </div>
                    </div>
                </article>
        </section>
        <section class="passengers">
         {% for message in app.flashes('errorPassager') %}
                <div class="alert_danger">{{message}}</div>
            {% endfor %}
            <div class="ico"><i class="fa-solid fa-users ico_fa"></i><h2>Passagers</h2></div>
                <form action="{{ path('reservation.recap') }}" method="POST">
                    <div class="fields">
                        {% for i in 1.. passengers %}
                            <div class="passenger">
                                <div class="ico"><i class="fa-regular fa-user ico_fa"></i><h3>Passager numéro {{ i }}</h3></div>
                                <div class="form-group">
                                    <input id="passenger_{{ i }}_firstname"type="text" name="passengers[{{ i }}][firstname]" placeholder="Nom" required></input>
                                </div>
                                <div class="form-group">
                                    <input id="passenger_{{ i }}_lastname"type="text" name="passengers[{{ i }}][lastname]" placeholder="Prénom" required></input>
                                </div>
                            </div>
                        {% endfor %}
                        </div>
                    <div class="flex_between">
                        <a class="btn_back" href="{{ app.request.server.get('HTTP_REFERER') }}">Retour</a>
                        <button class="btn_primary btn_cta" type="submit">Confirmer ma réservation</button>
                    </div>
                    <input type="hidden" name="token" value="{{ csrf_token('reservation') }}"/>
                    <input type="hidden" name="departure" value="{{ departure.id }}">
                    <input type="hidden" name="return" value="{{ return.id }}">
                </form>
            </div>
        </section>
    </main>
</div>
{% endblock %}
