<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}LUXSPACE - Administration{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('./images/logo_s.png') }}"/>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        {% block description %}
            <meta name="description" content="Administration de LUXSPACE" />
        {% endblock %}
        {% block stylesheets %}
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vanillajs-datepicker@1.1.4/dist/css/datepicker.min.css">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css">
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {{ encore_entry_script_tags('chartjs') }}
            <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
        {% endblock %}
    </head>
    <body>
        <header>
            <div class="container">   
                <nav class="topbar">
                    <a href="{{ path('home') }}"><img class="topbar_logo" src="{{ asset('./images/logo.png')}}" alt="logo de LUXSPACE"></img></a>
                    <ul class="topbar_menu">
                        <li><a class="menu_link {{ isActive('admin')? 'active' }}" href="{{ path('admin')}}">SOMMAIRE</a></li>
                        <li><a class="menu_link {{ isActive('location')? 'active' }}" href="{{ path('location.index')}}">DESTINATIONS</a></li>
                        <li><a class="menu_link {{ isActive('user')? 'active' }}" href="{{ path('user.index')}}">UTILISATEURS</a></li>
                        <li><a class="menu_link {{ isActive('departure')? 'active' }}" href="{{ path('departure.index')}}">DÉPARTS</a></li>
                        <li><a class="menu_link {{ isActive('returned')? 'active' }}" href="{{ path('returned.index')}}">RETOURS</a></li>
                        <li><a class="menu_link {{ isActive('reservation')? 'active' }}" href="{{ path('reservation.index')}}">RÉSERVATIONS</a></li>
                    </ul>
                    <div class="topbar_btn_menu_mobile">
                        <svg class="burger_star" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 1 L13.8 10.2 L23 12 L13.8 13.8 L12 23 L10.2 13.8 L1 12 L10.2 10.2 Z"/>
                        </svg>
                    </div>
                </nav>
            </div>
        </header>
        {% block headImage %}{% endblock %}
        <div class="container">
            {% for message in app.flashes('success') %}
                <div class="alert_success">{{message}}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert_danger">{{message}}</div>
            {% endfor %}
        </div>
        <div class="content">
            {% block body %}{% endblock %}
        </div>
        <footer>
            <div class="container">
                <section class="content">
                    <img width="80" src="{{ asset('./images/logo.png') }}" alt="LUXSPACE">
                    <nav class="footer_nav">
                        <a href="{{ path('about') }}"><i class="fa-solid fa-circle-info"></i> À propos</a>
                        <a href="https://github.com/curvata/luxspace" target="_blank"><i class="fa-brands fa-github"></i> GitHub</a>
                    </nav>
                    <p class="footer_credit">Développé par <a href="https://cancelinha.lu" target="_blank">Cancelinha</a></p>
                </section>
            </div>
        </footer>
    </body>
</html>
