<article class="card">
    <div class="card_image">
        <a href="{{ path('destination.show', {'id': destination[0].id })}}">
            <img src="{{ asset('images/location/' ~ destination[0].pictureHeader) }}" alt="{{ destination[0].title }}" loading="lazy">
        </a>
    </div>
    <div class="card_title">
        <h3>{{ destination[0].title }}</h3>
    </div>
    <div class="card_content">
        <p class="description">{{ destination[0].shortDescription }}</p>
        <div class="bottom">
            <p>à partir de <span class="price">{{ destination.minPrice|number_format(2, '.', ',') }} €</span></p>
            <a class="btn_secondary" href="{{ path('destination.show', {'id': destination[0].id })}}">Explorer</a>
        </div>
    </div>
</article>
