<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture {{ reservation.reference }}</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            height: 100%;
        }

        body {
            background-color: #06060f;
            color: #e8e8f2;
            font-family: 'DM Sans', Arial, sans-serif;
            font-size: 13px;
            line-height: 1.5;
            padding: 32px 40px;
            display: flex;
            flex-direction: column;
        }

        .invoice {
            width: 100%;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
        }
        .header img { width: 100px; opacity: 0.95; }
        .header-right { text-align: right; }
        .header-right h1 {
            font-size: 22px;
            font-weight: 700;
            color: #d4a843;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }
        .header-right .ref {
            font-size: 11px;
            color: #6868a0;
            margin-top: 3px;
            letter-spacing: 0.08em;
        }

        /* Divider */
        .divider {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.07);
            margin: 0 0 20px;
        }

        /* Parties */
        .parties {
            display: flex;
            justify-content: space-between;
            gap: 2rem;
            margin-bottom: 20px;
        }
        .party { flex: 1; }
        .party-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #d4a843;
            margin-bottom: 6px;
        }
        .party-name {
            font-size: 14px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 2px;
        }
        .party-detail { color: #6868a0; font-size: 12px; }

        /* Meta */
        .meta {
            display: flex;
            gap: 1rem;
            margin-bottom: 20px;
        }
        .meta-item {
            background-color: #0d0d1f;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 6px;
            padding: 10px 16px;
        }
        .meta-item .label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #6868a0;
            margin-bottom: 3px;
        }
        .meta-item .value {
            font-size: 13px;
            font-weight: 600;
            color: #e8e8f2;
        }

        /* Table */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 16px;
        }
        thead th {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #6868a0;
            padding: 8px 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            text-align: left;
        }
        thead th:last-child { text-align: right; }
        tbody td {
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            color: #b0b0cc;
            font-size: 12px;
            vertical-align: top;
        }
        tbody td:last-child { text-align: right; color: #e8e8f2; font-weight: 500; }
        tbody tr:last-child td { border-bottom: none; }
        .flight-title { color: #e8e8f2; font-weight: 500; margin-bottom: 2px; }
        .flight-sub { color: #6868a0; font-size: 11px; }

        /* Total */
        .total-block {
            background: linear-gradient(135deg, rgba(212,168,67,0.08), rgba(212,168,67,0.03));
            border: 1px solid rgba(212,168,67,0.25);
            border-radius: 6px;
            padding: 14px 20px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 2rem;
            margin-bottom: 20px;
        }
        .total-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #6868a0;
        }
        .total-amount {
            font-size: 20px;
            font-weight: 700;
            color: #d4a843;
        }

        /* Passengers */
        .section-title {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #6868a0;
            margin-bottom: 10px;
        }
        .passengers {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 20px;
        }
        .passenger-tag {
            background-color: #0d0d1f;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 20px;
            padding: 3px 12px;
            font-size: 12px;
            color: #a8a8cc;
        }

        .spacer { flex: 1; }

        /* Footer */
        .footer {
            border-top: 1px solid rgba(255,255,255,0.07);
            padding-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }
        .footer p { font-size: 12px; color: #6868a0; }

        @media print {
            @page { size: A4 portrait; margin: 16mm 20mm; }
            body {
                background: #06060f !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
<div class="invoice">

    <div class="header">
        <img src="{{ absolute_url(asset('./images/logo.png')) }}" alt="LUXSPACE">
        <div class="header-right">
            <h1>Facture</h1>
            <p class="ref">{{ reservation.reference }}</p>
        </div>
    </div>

    <hr class="divider">

    <div class="parties">
        <div class="party">
            <p class="party-label">De</p>
            <p class="party-name">LUXSPACE</p>
            <p class="party-detail">Agence de voyages spatiaux</p>
            <p class="party-detail">Luxembourg, LU</p>
        </div>
        <div class="party" style="text-align:right;">
            <p class="party-label">Pour</p>
            <p class="party-name">{{ reservation.client.firstname }} {{ reservation.client.lastname }}</p>
            <p class="party-detail">{{ reservation.client.email }}</p>
        </div>
    </div>

    <div class="meta">
        <div class="meta-item">
            <p class="label">Date d'émission</p>
            <p class="value">{{ reservation.createAt|date("d/m/Y") }}</p>
        </div>
        <div class="meta-item">
            <p class="label">Statut</p>
            <p class="value" style="color: {% if reservation.status == 'Payé' %}#4ecb71{% else %}#ff4d6d{% endif %};">{{ reservation.status }}</p>
        </div>
        <div class="meta-item">
            <p class="label">Passagers</p>
            <p class="value">{{ reservation.passengers|length }}</p>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th>Qté</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <p class="flight-title">✦ Vol aller — Luxembourg › {{ reservation.departure.destination.title }}</p>
                    <p class="flight-sub">{{ reservation.departure.reference }} · {{ reservation.departure.date|date('d/m/Y H:i') }}</p>
                </td>
                <td>{{ reservation.passengers|length }}</td>
                <td>{{ reservation.departureprice|number_format(2, ',', ' ') }} €</td>
                <td>{{ (reservation.departureprice * reservation.passengers|length)|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td>
                    <p class="flight-title">✦ Vol retour — {{ reservation.returned.ffrom.title }} › Luxembourg</p>
                    <p class="flight-sub">{{ reservation.returned.reference }} · {{ reservation.returned.date|date('d/m/Y H:i') }}</p>
                </td>
                <td>{{ reservation.passengers|length }}</td>
                <td>{{ reservation.returnprice|number_format(2, ',', ' ') }} €</td>
                <td>{{ (reservation.returnprice * reservation.passengers|length)|number_format(2, ',', ' ') }} €</td>
            </tr>
        </tbody>
    </table>

    <div class="total-block">
        <span class="total-label">Total TTC</span>
        <span class="total-amount">{{ ((reservation.departureprice + reservation.returnprice) * reservation.passengers|length)|number_format(2, ',', ' ') }} €</span>
    </div>

    <p class="section-title">Passagers</p>
    <div class="passengers">
        {% for passenger in reservation.passengers %}
            <span class="passenger-tag">{{ passenger.firstname }} {{ passenger.lastname }}</span>
        {% endfor %}
    </div>

    <div class="footer">
        <p>LUXSPACE — Agence de voyages spatiaux · Luxembourg</p>
        <p>{{ reservation.reference }}</p>
    </div>

</div>
</body>
</html>
