{% extends 'base.html.twig' %}

{% block title %}LUXSPACE - Mon compte{% endblock %}
{% block description %}
    <meta name="description" content="Tableau de bord de votre compte LUXSPACE" />
{% endblock %}

{% block body %}
<div class="container">
    <main>
        {% block title_cat %}
        <div class="ico">
            <i class="fa-solid fa-gauge-high ico_fa"></i>
            <h1>Tableau de bord</h1>
        </div>
        {% endblock %}

        <section class="account">
            {% block accountContent %}
                <h2>Bonjour {{ app.user.firstname }},</h2>
                <p>Gérez vos réservations, votre profil et votre mot de passe depuis votre espace personnel.</p>

                <div class="summary">
                    {% if nextDeparture is not null %}
                        <div class="ico">
                            <i class="fa-solid fa-rocket ico_fa dep"></i>
                            <p>
                                {% if nextDeparture.date.days == 0 %}
                                    C'est le grand jour — vous décollez pour
                                    {% if nextDeparture.reservation.departure.destination.title == "Lune" %}la {% endif %}
                                    <strong>{{ nextDeparture.reservation.departure.destination.title }}</strong> !
                                {% else %}
                                    Décollage dans <strong>{{ nextDeparture.date.days }} jour{{ nextDeparture.date.days > 1 ? 's' : '' }}</strong> vers
                                    {% if nextDeparture.reservation.departure.destination.title == "Lune" %}la {% endif %}
                                    <strong>{{ nextDeparture.reservation.departure.destination.title }}</strong>
                                {% endif %}
                            </p>
                        </div>
                    {% endif %}

                    <div class="dashboard_cards">
                        <a class="dashboard_card" href="{{ path('account.profil') }}">
                            <i class="fa-solid fa-address-card"></i>
                            <span class="dashboard_card_title">Mes coordonnées</span>
                            <span class="dashboard_card_desc">Nom, prénom, email</span>
                        </a>
                        <a class="dashboard_card" href="{{ path('account.profil.password') }}">
                            <i class="fa-solid fa-lock"></i>
                            <span class="dashboard_card_title">Mot de passe</span>
                            <span class="dashboard_card_desc">Modifier mon mot de passe</span>
                        </a>
                        <a class="dashboard_card dashboard_card--gold" href="{{ path('account.reservations') }}">
                            <i class="fa-solid fa-ticket"></i>
                            <span class="dashboard_card_title">Mes réservations</span>
                            <span class="dashboard_card_desc">Historique et détails</span>
                        </a>
                    </div>
                </div>
            {% endblock %}
        </section>
    </main>
</div>
{% endblock %}
