{% extends 'base.html.twig' %}

{% block title %}LUXSPACE - Connexion{% endblock %}
{% block description %}
    <meta name="description" content="Se connecter à son compte LUXSPACE" />
{% endblock %}

{% block body %}
<div class="container">
    <main>
        <div class="flex_center">
            <section class="middle">
                <h1 class="htitle_center">Connexion</h1>
                <p class="subtitle"><span>Accédez à votre espace personnel</span></p>

                {% if error %}
                    <div class="alert_danger">
                        {{ error.messageKey | trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="POST">
                    <div class="form-group">
                        <label for="email">Adresse e-mail</label>
                        <input type="email" id="email" name="email" class="form-field" placeholder="votre@email.com" autocomplete="email">
                    </div>
                    <div class="form-group">
                        <label for="password">Mot de passe</label>
                        <input class="form-field" type="password" id="password" name="password" placeholder="••••••••" autocomplete="current-password">
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <div class="form-group form-group--remember">
                        <label class="remember_label">
                            <input type="checkbox" name="_remember_me" class="remember_checkbox">
                            <span>Se souvenir de moi</span>
                        </label>
                    </div>
                    <div class="form-group">
                        <button class="btn_primary full" type="submit">Se connecter</button>
                    </div>
                </form>

                <div class="after_login">
                    <a href="{{ path('password.recovery.index') }}">Mot de passe oublié ?</a>
                    <a href="{{ path('register') }}">Créer un compte</a>
                </div>
            </section>
        </div>
    </main>
</div>
{% endblock %}
