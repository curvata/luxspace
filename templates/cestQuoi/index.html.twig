{% extends 'base.html.twig' %}

{% block title %}LUXSPACE - À propos{% endblock %}
{% block description %}
    <meta name="description" content="À propos de LUXSPACE"/>
{% endblock %}
{% block body %}
<div class="container">
    <main>
        <div class="flex_center">
            <section class="middle">
                <h1 class="htitle_center">Qu'est-ce que LUXSPACE ?</h1>
                <p class="subtitle"><span>Application web fictive de réservation de vols spatiaux</span></p>
                <p>LUXSPACE est une application web fictive de réservation de vols spatiaux.</p>
                <p>Ce projet, développé en 2021 avec <strong>Symfony</strong>, a été réalisé dans le cadre de mon <strong>portfolio personnel</strong> afin de mettre en avant mes compétences en conception d'applications web.</p>
                <p style="font-size:0.88rem; color:var(--text-muted); margin-top:0.6rem;">
                    <i class="fa-brands fa-github" style="margin-right:0.4rem;"></i>Code source disponible sur <a href="https://github.com/curvata/luxspace" target="_blank" style="color:var(--gold); font-weight:600;">GitHub</a>
                </p>
                <p style="margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border); font-size:0.88rem; color:var(--text-muted);">
                    Découvrez mes autres projets sur <a href="https://cancelinha.lu" target="_blank" style="color:var(--gold); font-weight:600;">cancelinha.lu</a>
                </p>
            </section>
        </div>
    </main>
</div>
{% endblock %}