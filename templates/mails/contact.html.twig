{% extends 'mails/mail.html.twig' %}

{% block body %}
    <p style="margin:0 0 8px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#d4a843;">
        ✦ Nouveau message — Formulaire de contact
    </p>

    <h1 style="margin:0 0 24px; font-size:22px; font-weight:700; color:#ffffff; line-height:1.3;">
        Message reçu
    </h1>

    <table cellpadding="0" cellspacing="0" style="width:100%; margin-bottom:24px;">
        <tr>
            <td style="padding:12px 16px; background-color:rgba(255,255,255,0.04); border-bottom:1px solid rgba(255,255,255,0.06);">
                <span style="font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#6b6b8a;">Nom</span><br>
                <span style="font-size:15px; color:#e8e8f2;">{{ content.lastname }} {{ content.firstname }}</span>
            </td>
        </tr>
        <tr>
            <td style="padding:12px 16px; background-color:rgba(255,255,255,0.04); border-bottom:1px solid rgba(255,255,255,0.06);">
                <span style="font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#6b6b8a;">E-mail</span><br>
                <span style="font-size:15px; color:#e8e8f2;">{{ content.email }}</span>
            </td>
        </tr>
        <tr>
            <td style="padding:12px 16px; background-color:rgba(255,255,255,0.04);">
                <span style="font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#6b6b8a;">Message</span><br>
                <span style="font-size:15px; color:#e8e8f2; line-height:1.7;">{{ content.message }}</span>
            </td>
        </tr>
    </table>
{% endblock %}
