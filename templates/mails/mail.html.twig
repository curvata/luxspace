<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUXSPACE</title>
</head>
<body style="margin:0; padding:0; background-color:#06060f; font-family:'DM Sans', Arial, sans-serif; color:#e8e8f2;">

    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding:40px 20px 0;">
                <img src="{{ absolute_url(asset('./images/logo.png')) }}" width="110" alt="LUXSPACE" style="display:block; margin-bottom:24px;">
                <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#0d0d1f; border-radius:12px; border:1px solid rgba(255,255,255,0.08); overflow:hidden;">
                    <tr>
                        <td style="padding:40px;">
                            {% block body %}{% endblock %}
                        </td>
                    </tr>
                </table>
                <p style="margin:24px 0 0; font-size:12px; color:#6b6b8a;">LUXSPACE — Agence de voyages spatiaux</p>
            </td>
        </tr>
    </table>

</body>
</html>
