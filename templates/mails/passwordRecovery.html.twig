{% extends 'mails/mail.html.twig' %}

{% block body %}
    <p style="margin:0 0 8px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#d4a843;">
        ✦ Réinitialisation du mot de passe
    </p>

    <h1 style="margin:0 0 24px; font-size:22px; font-weight:700; color:#ffffff; line-height:1.3;">
        Bonjour {{ content.user.firstname }},
    </h1>

    <p style="margin:0 0 24px; font-size:15px; color:#b0b0cc; line-height:1.7;">
        Vous avez demandé à réinitialiser votre mot de passe. Cliquez sur le bouton ci-dessous pour en choisir un nouveau.<br><br>
        Si vous n'êtes pas à l'origine de cette demande, ignorez simplement cet email.
    </p>

    <a href="{{ absolute_url(path('password.recovery', {'token': content.token})) }}" style="display:inline-block; padding:12px 24px; background:linear-gradient(135deg,#b8902e,#d4a843); color:#0a0a16; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border-radius:6px;">
        Réinitialiser mon mot de passe
    </a>
{% endblock %}
