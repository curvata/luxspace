{% extends 'mails/mail.html.twig' %}

{% block body %}
    <!-- Eyebrow -->
    <p style="margin:0 0 8px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#d4a843;">
        ✦ Confirmation de réservation
    </p>

    <h1 style="margin:0 0 24px; font-size:22px; font-weight:700; color:#ffffff; line-height:1.3;">
        Bonjour {{ content.client.firstname }},
    </h1>

    <p style="margin:0 0 16px; font-size:15px; color:#b0b0cc; line-height:1.7;">
        Nous vous remercions pour votre commande et vous souhaitons d'ores et déjà un excellent voyage vers
        {% if content.departure.destination.title == "Lune" %}la {% endif %}<strong style="color:#e8e8f2;">{{ content.departure.destination.title }}</strong>.
    </p>

    <!-- Reservation reference -->
    <table cellpadding="0" cellspacing="0" style="margin:24px 0; width:100%; background-color:rgba(212,168,67,0.07); border-left:3px solid #d4a843; border-radius:4px;">
        <tr>
            <td style="padding:16px 20px;">
                <p style="margin:0 0 4px; font-size:11px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#d4a843;">Numéro de réservation</p>
                <p style="margin:0; font-size:18px; font-weight:700; color:#ffffff;">{{ content.reference }}</p>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 32px; font-size:14px; color:#b0b0cc; line-height:1.7;">
        Retrouvez tous les détails de votre vol depuis votre espace personnel.
    </p>

    <!-- Buttons -->
    <table cellpadding="0" cellspacing="0">
        <tr>
            <td style="padding-right:12px;">
                <a href="{{ url('account.index') }}" style="display:inline-block; padding:12px 24px; background:linear-gradient(135deg,#b8902e,#d4a843); color:#0a0a16; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border-radius:6px;">
                    Mon compte
                </a>
            </td>
            <td>
                <a href="{{ url('account.reservations.incoice', {'id': content.id}) }}" style="display:inline-block; padding:12px 24px; background:transparent; color:#d4a843; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; border-radius:6px; border:1px solid rgba(212,168,67,0.4);">
                    Voir ma facture
                </a>
            </td>
        </tr>
    </table>
{% endblock %}
